APP_NAME=Preventec Franquias API
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

POSTGRES_SERVER=postgres
POSTGRES_PORT=5432
POSTGRES_DB=preventec_franquias
POSTGRES_USER=preventec_user
POSTGRES_PASSWORD=preventec_password

DATABASE_URL=postgresql://preventec_user:preventec_password@postgres:5432/preventec_franquias

SECRET_KEY=change_this_in_production_preventec_secret_key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

UPLOAD_DIR=/app/uploads
BASE_FILE_URL=http://localhost:8000/uploads